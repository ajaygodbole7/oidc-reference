# Local reference defaults. These match the checked-in Keycloak realm and are
# safe only for local development.

CSRF_SIGNING_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AUTH_CLIENT_ID=oidc-reference-auth
AUTH_CLIENT_SECRET=LOCAL_DEV_AUTH_CLIENT_SECRET__CHANGE_BEFORE_DEPLOY
GATEWAY_CLIENT_SECRET=LOCAL_DEV_GATEWAY_CLIENT_SECRET__CHANGE_BEFORE_DEPLOY

OIDC_ISSUER_URI=http://localhost:8080/realms/oidc-reference
APP_AUTHORIZATION_URI=http://localhost:8080/realms/oidc-reference/protocol/openid-connect/auth
APP_TOKEN_URI=http://keycloak:8080/realms/oidc-reference/protocol/openid-connect/token
APP_JWKS_URI=http://keycloak:8080/realms/oidc-reference/protocol/openid-connect/certs
APP_END_SESSION_URI=http://localhost:8080/realms/oidc-reference/protocol/openid-connect/logout

OIDC_SCOPES=openid,profile,email,roles,api.audience,api.read
OIDC_AUDIENCE=oidc-reference-api
OIDC_ROLES_CLAIM_PATH=realm_access,roles
APP_REFRESH_REQUIRE_ROTATION=true
